import Link from "next/link";
import {
  FileText,
  Wallet,
  Users,
  Clock,
  TrendingUp,
  TrendingDown,
  ArrowRight,
  AlertCircle,
} from "lucide-react";
import { Button } from "@/components/ui/button";
import { Badge } from "@/components/ui/badge";
import { formatCurrency, formatDate } from "@/lib/utils";
import {
  demoOS,
  demoClientes,
  demoResumoFinanceiro,
  statusOSConfig,
} from "@/lib/demo-data";

export const metadata = { title: "Dashboard" };

export default function DashboardPage() {
  // KPIs calculados a partir dos dados demo
  const osAbertas = demoOS.filter(
    (o) => !["entregue", "cancelada"].includes(o.status)
  ).length;
  const osAtrasadas = demoOS.filter(
    (o) =>
      o.dataPrevisao &&
      new Date(o.dataPrevisao) < new Date() &&
      !["entregue", "cancelada"].includes(o.status)
  ).length;
  const totalClientes = demoClientes.length;
  const novosClientesMes = 3;

  const kpis = [
    {
      label: "OS em aberto",
      value: osAbertas.toString(),
      icon: FileText,
      hint: `${osAtrasadas} atrasada(s)`,
      hintType: osAtrasadas > 0 ? "danger" : "neutral",
      color: "var(--color-brand-600)",
      bg: "var(--color-brand-50)",
    },
    {
      label: "Receita do mês",
      value: formatCurrency(demoResumoFinanceiro.receitaMes),
      icon: TrendingUp,
      hint: "+12% vs. mês anterior",
      hintType: "success",
      color: "var(--color-success)",
      bg: "var(--color-success-bg)",
    },
    {
      label: "Clientes ativos",
      value: totalClientes.toString(),
      icon: Users,
      hint: `${novosClientesMes} novo(s) este mês`,
      hintType: "neutral",
      color: "var(--color-info)",
      bg: "var(--color-info-bg)",
    },
    {
      label: "Ticket médio",
      value: formatCurrency(demoResumoFinanceiro.ticketMedio),
      icon: Wallet,
      hint: "+R$ 24 vs. mês anterior",
      hintType: "success",
      color: "var(--color-warning)",
      bg: "var(--color-warning-bg)",
    },
  ];

  const osRecentes = demoOS.slice(0, 5);

  const hintColors: Record<string, string> = {
    success: "text-[var(--color-success)]",
    danger: "text-[var(--color-danger)]",
    neutral: "text-[var(--color-fg-subtle)]",
  };

  return (
    <div className="space-y-6">
      {/* Header da página */}
      <div className="flex flex-col gap-2 sm:flex-row sm:items-center sm:justify-between">
        <div>
          <h1 className="text-2xl font-bold tracking-tight">Dashboard</h1>
          <p className="text-sm text-[var(--color-fg-muted)]">
            Visão geral da sua operação hoje.
          </p>
        </div>
        <Button asChild>
          <Link href="/os/nova">
            <FileText className="size-4" />
            Nova OS
          </Link>
        </Button>
      </div>

      {/* KPIs */}
      <div className="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
        {kpis.map((kpi) => (
          <div
            key={kpi.label}
            className="rounded-[var(--radius-lg)] border border-[var(--color-border)] bg-[var(--color-surface)] p-5 shadow-sm"
          >
            <div className="flex items-center justify-between">
              <div
                className="flex size-10 items-center justify-center rounded-[var(--radius-md)]"
                style={{ backgroundColor: kpi.bg, color: kpi.color }}
              >
                <kpi.icon className="size-5" />
              </div>
            </div>
            <p className="mt-4 text-2xl font-bold tracking-tight">{kpi.value}</p>
            <p className="text-sm text-[var(--color-fg-muted)]">{kpi.label}</p>
            <p className={`mt-1 text-xs font-medium ${hintColors[kpi.hintType]}`}>
              {kpi.hint}
            </p>
          </div>
        ))}
      </div>

      {/* Alerta de OS atrasadas */}
      {osAtrasadas > 0 && (
        <div className="flex items-center gap-3 rounded-[var(--radius-lg)] border border-[var(--color-warning)]/30 bg-[var(--color-warning-bg)] px-5 py-4">
          <AlertCircle className="size-5 shrink-0 text-[var(--color-warning)]" />
          <div className="flex-1">
            <p className="text-sm font-semibold text-[var(--color-warning)]">
              Você tem {osAtrasadas} ordem(ns) de serviço atrasada(s)
            </p>
            <p className="text-xs text-[var(--color-fg-muted)]">
              Revise as OS com previsão vencida para manter a satisfação dos
              clientes.
            </p>
          </div>
          <Button size="sm" variant="outline" asChild>
            <Link href="/os?filtro=atrasadas">Ver detalhes</Link>
          </Button>
        </div>
      )}

      {/* Grid principal */}
      <div className="grid gap-6 lg:grid-cols-3">
        {/* OS Recentes */}
        <div className="lg:col-span-2">
          <div className="rounded-[var(--radius-lg)] border border-[var(--color-border)] bg-[var(--color-surface)] shadow-sm">
            <div className="flex items-center justify-between border-b border-[var(--color-border)] px-5 py-4">
              <h2 className="font-semibold">Ordens de serviço recentes</h2>
              <Link
                href="/os"
                className="inline-flex items-center gap-1 text-sm font-medium text-[var(--color-brand-600)] hover:underline"
              >
                Ver todas
                <ArrowRight className="size-3.5" />
              </Link>
            </div>
            <div className="divide-y divide-[var(--color-border)]">
              {osRecentes.map((os) => {
                const cfg = statusOSConfig[os.status];
                return (
                  <Link
                    key={os.id}
                    href={`/os/${os.id}`}
                    className="flex items-center gap-4 px-5 py-3.5 transition-colors hover:bg-[var(--color-surface-muted)]"
                  >
                    <div className="min-w-0 flex-1">
                      <div className="flex items-center gap-2">
                        <span className="text-sm font-semibold">{os.numero}</span>
                        <span
                          className="rounded-full px-2 py-0.5 text-xs font-medium"
                          style={{ backgroundColor: cfg.bg, color: cfg.color }}
                        >
                          {cfg.label}
                        </span>
                      </div>
                      <p className="mt-0.5 truncate text-sm text-[var(--color-fg-muted)]">
                        {os.clienteNome} · {os.equipamentoNome}
                      </p>
                    </div>
                    <div className="hidden text-right sm:block">
                      <p className="text-sm font-semibold">
                        {os.valorTotal > 0
                          ? formatCurrency(os.valorTotal)
                          : "—"}
                      </p>
                      <p className="text-xs text-[var(--color-fg-subtle)]">
                        Aberta em {formatDate(os.dataAbertura)}
                      </p>
                    </div>
                  </Link>
                );
              })}
            </div>
          </div>
        </div>

        {/* Resumo Financeiro */}
        <div className="space-y-6">
          <div className="rounded-[var(--radius-lg)] border border-[var(--color-border)] bg-[var(--color-surface)] p-5 shadow-sm">
            <h2 className="font-semibold">Resumo financeiro</h2>
            <div className="mt-4 space-y-3">
              <div className="flex items-center justify-between">
                <div className="flex items-center gap-2">
                  <div className="flex size-8 items-center justify-center rounded-full bg-[var(--color-success-bg)] text-[var(--color-success)]">
                    <TrendingUp className="size-4" />
                  </div>
                  <span className="text-sm text-[var(--color-fg-muted)]">
                    A receber
                  </span>
                </div>
                <span className="text-sm font-semibold">
                  {formatCurrency(demoResumoFinanceiro.aReceber)}
                </span>
              </div>
              <div className="flex items-center justify-between">
                <div className="flex items-center gap-2">
                  <div className="flex size-8 items-center justify-center rounded-full bg-[var(--color-danger-bg)] text-[var(--color-danger)]">
                    <TrendingDown className="size-4" />
                  </div>
                  <span className="text-sm text-[var(--color-fg-muted)]">
                    A pagar
                  </span>
                </div>
                <span className="text-sm font-semibold">
                  {formatCurrency(demoResumoFinanceiro.aPagar)}
                </span>
              </div>
              <div className="border-t border-[var(--color-border)] pt-3">
                <div className="flex items-center justify-between">
                  <span className="text-sm font-semibold">Saldo projetado</span>
                  <span className="text-lg font-bold text-[var(--color-success)]">
                    {formatCurrency(
                      demoResumoFinanceiro.aReceber -
                        demoResumoFinanceiro.aPagar
                    )}
                  </span>
                </div>
              </div>
            </div>
            <Button variant="outline" className="mt-4 w-full" asChild>
              <Link href="/financeiro">Ver financeiro</Link>
            </Button>
          </div>

          {/* Atividade recente */}
          <div className="rounded-[var(--radius-lg)] border border-[var(--color-border)] bg-[var(--color-surface)] p-5 shadow-sm">
            <h2 className="font-semibold">Atividade recente</h2>
            <div className="mt-4 space-y-3">
              {[
                {
                  icon: Clock,
                  text: "OS-2026-0040 marcada como Pronto",
                  time: "há 2 horas",
                },
                {
                  icon: Users,
                  text: "Novo cliente: Fernanda Costa Lima",
                  time: "há 5 horas",
                },
                {
                  icon: Wallet,
                  text: "Pagamento registrado: R$ 650,00",
                  time: "há 1 dia",
                },
              ].map((act, i) => (
                <div key={i} className="flex items-start gap-3">
                  <div className="flex size-8 shrink-0 items-center justify-center rounded-full bg-[var(--color-surface-muted)] text-[var(--color-fg-muted)]">
                    <act.icon className="size-4" />
                  </div>
                  <div>
                    <p className="text-sm">{act.text}</p>
                    <p className="text-xs text-[var(--color-fg-subtle)]">
                      {act.time}
                    </p>
                  </div>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </div>
  );
}